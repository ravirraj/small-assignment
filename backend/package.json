{
  "name": "product-browser-api",
  "version": "1.0.0",
  "description": "Production-quality backend for browsing 200,000 products with cursor-based pagination",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:setup": "node scripts/setup-db.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/setup-db.js && node scripts/seed.js"
  },
  "dependencies": {
    "@faker-js/faker": "^9.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1"
  }
}
